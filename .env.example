# Copy to .env and fill in. .env is gitignored — never commit real values.

# Which venue to trade on: alpaca | coinbase | fake
VENUE=alpaca

# Alpaca (paper trading by default). Keys: https://app.alpaca.markets/ → API Keys.
# Symbol format for Alpaca crypto is BTC/USD.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# Coinbase Advanced Trade (sandbox by default). Keys via the Coinbase Developer
# Platform (CDP). Symbol format for Coinbase is BTC-USD.
# Note: Coinbase sandbox responses are useful for integration checks but can be
# mocked/static for some workflows.
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_SANDBOX=true

# Market symbol (match the selected venue's format) and bar timeframe.
SYMBOL=BTC/USD
TIMEFRAME=5Min
ORDER_QTY=0.001
