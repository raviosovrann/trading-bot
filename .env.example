# Copy to .env and fill in. .env is gitignored — never commit real values.

# Which venue to trade on: alpaca | coinbase | fake
VENUE=alpaca

# Alpaca (paper trading by default). Keys: https://app.alpaca.markets/ → API Keys.
# Symbol format for Alpaca crypto is BTC/USD.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# Coinbase Advanced Trade. Keys via the Coinbase Developer Platform (CDP).
# Symbol format for Coinbase is BTC-USD.
# COINBASE_SANDBOX=true switches the client to the sandbox host
# (api-sandbox.coinbase.com). The sandbox returns static/mocked responses in
# the same format as production for Accounts + Orders endpoints — good for
# integration testing without real money, but NOT realistic fills or PnL.
# COINBASE_SANDBOX=false hits production api.coinbase.com and moves REAL funds:
# use a limited-permission key and a tiny ORDER_QTY.
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_SANDBOX=true

# Market symbol (match the selected venue's format) and bar timeframe.
SYMBOL=BTC/USD
TIMEFRAME=5Min
ORDER_QTY=0.001
