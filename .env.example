# Copy to .env and fill in. .env is gitignored — never commit real values.

# Which venue to trade on: alpaca | coinbase | fake
VENUE=alpaca

# Alpaca (paper trading by default). Keys: https://app.alpaca.markets/ → API Keys.
# Symbol format for Alpaca crypto is BTC/USD.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# Coinbase Advanced Trade (PRODUCTION / real money). Keys via the Coinbase
# Developer Platform (CDP). Symbol format for Coinbase is BTC-USD.
# Note: Coinbase Advanced Trade has NO separate REST sandbox. COINBASE_SANDBOX
# is accepted for interface parity only and does NOT switch hosts — every call
# hits production api.coinbase.com and moves real funds. Use a limited-
# permission key and a tiny ORDER_QTY. Prefer Alpaca paper for testing.
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_SANDBOX=true

# Market symbol (match the selected venue's format) and bar timeframe.
SYMBOL=BTC/USD
TIMEFRAME=5Min
ORDER_QTY=0.001
