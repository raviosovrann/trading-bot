# Copy to .env and fill in. .env is gitignored — never commit real values.

# Exchange to trade on: any ccxt exchange id (coinbase, kraken, ...).
EXCHANGE=coinbase

# API credentials for the exchange above.
# Coinbase (and OKX/KuCoin) also require a passphrase -> API_PASSWORD.
API_KEY=
API_SECRET=
API_PASSWORD=

# Market symbol (ccxt unified format, e.g. BTC/USD, DOGE/USD) and bar timeframe
# (ccxt unified: 1m, 5m, 15m, 1h, 1d).
SYMBOL=DOGE/USD
TIMEFRAME=5m
ORDER_QTY=10

# STREAM=1 -> live event-driven WebSocket streaming; 0 -> single-shot.
STREAM=0

# LIVE guard. LEFT UNSET/0 = DRY RUN: the bot fetches data, runs the strategy,
# and LOGS the order it would place, but sends NOTHING to the exchange.
# LIVE=1 places REAL orders that move REAL money. Verify in dry-run first.
LIVE=0
